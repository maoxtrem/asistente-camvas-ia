<div
    id="asistentecamvasia-widget"
    class="asistentecamvasia-widget"
    data-widget-locale="{{ locale|e('html_attr') }}"
    data-widget-title="{{ widgetTitle|e('html_attr') }}"
    data-widget-label="{{ widgetLabel|e('html_attr') }}"
    data-tenant="{{ tenantName|e('html_attr') }}"
    data-usuario="{{ usuarioName|e('html_attr') }}"
    data-entorno="{{ canvasEnvironment|e('html_attr') }}"
    data-images-limit="{{ imagesLimit|e('html_attr') }}"
    data-images-endpoint="{{ imagesEndpoint|e('html_attr') }}"
    data-ui-close-label="{{ ui.close_label|e('html_attr') }}"
    data-ui-status-connected="{{ ui.status_connected|e('html_attr') }}"
    data-ui-status-offline="{{ ui.status_offline|e('html_attr') }}"
    data-ui-composer-label="{{ ui.composer_label|e('html_attr') }}"
    data-ui-placeholder="{{ ui.placeholder|e('html_attr') }}"
    data-ui-send-label="{{ ui.send_label|e('html_attr') }}"
    data-ui-sending-label="{{ ui.sending_label|e('html_attr') }}"
    data-ui-user-label="{{ ui.user_label|e('html_attr') }}"
    data-ui-assistant-label="{{ ui.assistant_label|e('html_attr') }}"
    data-ui-no-endpoint="{{ ui.no_endpoint|e('html_attr') }}"
    data-ui-response-received="{{ ui.response_received|e('html_attr') }}"
    data-ui-design-applied="{{ ui.design_applied|e('html_attr') }}"
    data-ui-send-failed="{{ ui.send_failed|e('html_attr') }}"
>
    <section id="asistentecamvasia-panel" class="asistentecamvasia-panel" aria-hidden="true">
        <header class="asistentecamvasia-panel__header">
            <strong>{{ widgetTitle }}</strong>
            <button id="asistentecamvasia-close" type="button" class="asistentecamvasia-panel__close" aria-label="{{ ui.close_label|e('html_attr') }}">×</button>
        </header>

        <div class="asistentecamvasia-panel__body">
            <div class="asistentecamvasia-status asistentecamvasia-status--{{ connection.ok ? 'ok' : 'error' }}">
                <span
                    class="asistentecamvasia-status__dot"
                    title="{{ connection.ok ? ui.status_connected : ui.status_offline }}"
                    aria-label="{{ connection.ok ? ui.status_connected : ui.status_offline }}"
                >
                    <span class="visually-hidden">
                        {{ connection.ok ? ui.status_connected : ui.status_offline }}
                    </span>
                </span>
            </div>

            <section class="asistentecamvasia-gallery" aria-label="Galeria de imagenes">
                <div class="asistentecamvasia-gallery__header">
                    <strong>Imagenes creadas</strong>
                    <small class="asistentecamvasia-gallery__hint">Pulsa una miniatura para insertarla en el lienzo</small>
                </div>
                <div id="asistentecamvasia-gallery" class="asistentecamvasia-gallery__grid" aria-live="polite">
                    <p class="asistentecamvasia-gallery__empty">Cargando imagenes...</p>
                </div>
            </section>

            <div id="asistentecamvasia-chat" class="asistentecamvasia-chat">
                <div id="asistentecamvasia-messages" class="asistentecamvasia-chat__messages" aria-live="polite" aria-label="{{ ui.chat_history_label|e('html_attr') }}"></div>

                <form
                    id="asistentecamvasia-form"
                    class="asistentecamvasia-chat__composer"
                    data-generate-endpoint="{{ path('asistentecamvasia_canvas_generate') }}"
                >
                    <label for="asistentecamvasia-message" class="asistentecamvasia-chat__label">
                        {{ ui.composer_label }}
                    </label>
                    <textarea
                        id="asistentecamvasia-message"
                        class="asistentecamvasia-chat__input"
                        rows="3"
                        placeholder="{{ ui.placeholder|e('html_attr') }}"
                    ></textarea>

                    <div class="asistentecamvasia-chat__actions">
                        <button id="asistentecamvasia-send" type="submit" class="asistentecamvasia-chat__send">
                            {{ ui.send_label }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>
</div>

<link rel="stylesheet" href="{{ asset('bundles/asistentecamvasia/css/asistente-camvasia-widget.css') }}">
<script defer src="{{ asset('bundles/asistentecamvasia/js/asistente-camvas-ia.js') }}"></script>
<script type="module" src="{{ asset('bundles/asistentecamvasia/js/main.js') }}"></script>
